generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth & Users ───────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(EDITOR)
  avatar       String?
  bio          String?
  socialLinks  Json? // { linkedin, x, github, instagram }
  posts        Post[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

enum Role {
  ADMIN
  EDITOR
}

// ─── Blog ───────────────────────────────────────────────────

model Post {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String?
  content     Json // Tiptap JSON document
  coverImage  String?
  authorId    String
  author      User      @relation(fields: [authorId], references: [id])
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  tags        Tag[]
  published   Boolean   @default(false)
  featured    Boolean   @default(false)
  publishedAt DateTime?
  readTime    Int? // minutes
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Category {
  id    String @id @default(cuid())
  slug  String @unique
  name  String
  posts Post[]
}

model Tag {
  id    String @id @default(cuid())
  slug  String @unique
  name  String
  posts Post[]
}

// ─── Services ───────────────────────────────────────────────

model Service {
  id               String    @id @default(cuid())
  slug             String    @unique
  name             String
  shortDescription String
  fullDescription  Json // Tiptap JSON
  icon             String // Lucide icon name
  techStack        String[] // e.g., ["React", "Node.js"]
  faqs             Json? // [{ question, answer }]
  order            Int       @default(0)
  published        Boolean   @default(true)
  projects         Project[] @relation("ProjectServices")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

// ─── Portfolio ──────────────────────────────────────────────

model Project {
  id               String    @id @default(cuid())
  slug             String    @unique
  title            String
  client           String?
  shortDescription String
  description      Json // Tiptap JSON
  challenge        Json?
  solution         Json?
  result           Json?
  coverImage       String
  images           String[]
  techStack        String[]
  services         Service[] @relation("ProjectServices")
  testimonial      Json? // { quote, author, role }
  startDate        DateTime?
  endDate          DateTime?
  published        Boolean   @default(false)
  featured         Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

// ─── Careers ────────────────────────────────────────────────

model Job {
  id               String        @id @default(cuid())
  slug             String        @unique
  title            String
  department       String
  location         String
  type             JobType
  description      Json // Tiptap JSON
  shortDescription String
  salaryMin        Int?
  salaryMax        Int?
  salaryCurrency   String?       @default("UGX")
  published        Boolean       @default(false)
  publishedAt      DateTime?
  closedAt         DateTime?
  applications     Application[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
}

model Application {
  id             String            @id @default(cuid())
  jobId          String
  job            Job               @relation(fields: [jobId], references: [id])
  fullName       String
  email          String
  phone          String
  resumeUrl      String
  coverLetter    String?
  portfolioUrl   String?
  linkedinUrl    String?
  referralSource String?
  notes          String?
  internalNotes  String?
  status         ApplicationStatus @default(NEW)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

enum ApplicationStatus {
  NEW
  REVIEWING
  INTERVIEW
  OFFERED
  REJECTED
  HIRED
}

// ─── Contact ────────────────────────────────────────────────

model Inquiry {
  id        String   @id @default(cuid())
  fullName  String
  email     String
  phone     String?
  service   String?
  budget    String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ─── Team ───────────────────────────────────────────────────

model TeamMember {
  id          String   @id @default(cuid())
  name        String
  role        String
  bio         String?
  photo       String?
  socialLinks Json? // { linkedin, x, github, instagram }
  order       Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Company Timeline ───────────────────────────────────────

model Milestone {
  id          String   @id @default(cuid())
  date        DateTime
  title       String
  description String?
  image       String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Media Library ──────────────────────────────────────────

model Media {
  id        String   @id @default(cuid())
  filename  String
  url       String
  mimeType  String
  size      Int // bytes
  alt       String?
  createdAt DateTime @default(now())
}

// ─── Dynamic Content ────────────────────────────────────────

model SiteSettings {
  id           String   @id @default("default")
  companyName  String   @default("Rooibok Technologies")
  tagline      String?
  email        String?
  phone        String?
  address      String?
  socialLinks  Json? // { instagram, facebook, linkedin, x, tiktok }
  seoDefaults  Json? // { title, description, ogImage }
  footerConfig Json? // { columns: [{ heading, links }], copyright }
  navConfig    Json? // { ctaText, ctaLink }
  updatedAt    DateTime @updatedAt
}

model ContentBlock {
  id        String           @id @default(cuid())
  key       String           @unique
  content   Json
  type      ContentBlockType
  order     Int              @default(0)
  updatedAt DateTime         @updatedAt
}

enum ContentBlockType {
  TEXT
  RICH_TEXT
  IMAGE
  LINK
  GROUP
}

// ─── Popup System ───────────────────────────────────────────

model Popup {
  id              String         @id @default(cuid())
  name            String
  title           String?
  content         Json
  type            PopupType
  trigger         PopupTrigger
  delay           Int?
  scrollThreshold Int?
  pages           String[] // route patterns
  frequency       PopupFrequency
  frequencyDays   Int?
  startDate       DateTime?
  endDate         DateTime?
  active          Boolean        @default(true)
  ctaText         String?
  ctaLink         String?
  styleOverrides  Json?
  order           Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

enum PopupType {
  BANNER
  MODAL
  SLIDE_IN
  BOTTOM_BAR
}

enum PopupTrigger {
  ON_LOAD
  ON_SCROLL
  ON_EXIT_INTENT
  AFTER_DELAY
  ON_CLICK
}

enum PopupFrequency {
  ONCE_PER_SESSION
  ONCE_EVER
  ALWAYS
  EVERY_X_DAYS
}
